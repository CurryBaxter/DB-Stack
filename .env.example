COMPOSE_PROJECT_NAME=db-stack
TZ=Europe/Berlin
SECRETS_DIR=./secrets

POSTGRES_SUPERUSER=postgres
POSTGRES_DEFAULT_DB=postgres
POSTGRES_PORT_INTERNAL=5432
POSTGRES_SHM_SIZE=1g

APP_DB_NAME=app
APP_DB_USER=app_user

PGBACKREST_STANZA=main

POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=1GB
POSTGRES_EFFECTIVE_CACHE_SIZE=3GB
POSTGRES_MAINTENANCE_WORK_MEM=256MB
POSTGRES_WORK_MEM=16MB
POSTGRES_WAL_BUFFERS=16MB
POSTGRES_MIN_WAL_SIZE=1GB
POSTGRES_MAX_WAL_SIZE=4GB
POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
POSTGRES_RANDOM_PAGE_COST=1.1
POSTGRES_EFFECTIVE_IO_CONCURRENCY=200
POSTGRES_MAX_WORKER_PROCESSES=8
POSTGRES_MAX_PARALLEL_WORKERS=8
POSTGRES_MAX_PARALLEL_WORKERS_PER_GATHER=4
POSTGRES_MAX_WAL_SENDERS=10
POSTGRES_MAX_REPLICATION_SLOTS=10
POSTGRES_LOG_MIN_DURATION_STATEMENT=500ms
POSTGRES_LOG_CHECKPOINTS=on
POSTGRES_LOG_CONNECTIONS=off
POSTGRES_LOG_DISCONNECTIONS=off
POSTGRES_SHARED_PRELOAD_LIBRARIES=pg_stat_statements

PGBOUNCER_BIND_ADDRESS=127.0.0.1
PGBOUNCER_PORT=6432
PGBOUNCER_PORT_INTERNAL=6432
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=50
PGBOUNCER_RESERVE_POOL_SIZE=10
PGBOUNCER_RESERVE_POOL_TIMEOUT=5
PGBOUNCER_AUTH_USER=pgbouncer_auth
PGBOUNCER_ADMIN_USERS=postgres
PGBOUNCER_STATS_USERS=postgres_exporter
PGBOUNCER_SERVER_RESET_QUERY=DISCARD ALL

POSTGRES_EXPORTER_USER=postgres_exporter
POSTGRES_REPLICATION_USER=replicator

PROMETHEUS_BIND_ADDRESS=127.0.0.1
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_TIME=15d

GRAFANA_BIND_ADDRESS=127.0.0.1
GRAFANA_PORT=3000
GRAFANA_DOMAIN=localhost
GRAFANA_ROOT_URL=http://localhost:3000
GRAFANA_ADMIN_USER=admin
