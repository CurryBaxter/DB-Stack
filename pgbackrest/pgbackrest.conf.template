[global]
repo1-path=/var/lib/pgbackrest
repo1-retention-full=${BACKUP_REPO1_RETENTION_FULL}
repo1-retention-diff=${BACKUP_REPO1_RETENTION_DIFF}
repo1-bundle=y
repo1-block=y
start-fast=y
delta=y
process-max=${PGBACKREST_PROCESS_MAX}
log-level-console=info
log-level-file=detail
spool-path=/var/lib/pgbackrest/spool

${PGBACKREST_REPO2_BLOCK}

[${PGBACKREST_STANZA}]
pg1-path=${PGDATA}
pg1-port=5432
pg1-socket-path=/var/run/postgresql
